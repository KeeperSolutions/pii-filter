# Pipeline configuration (loaded by Pipelines container at runtime)
# All vars are optional — valves carry defaults. Override here when needed.
#   PII_FILTER_POSTGRES_URL=postgresql://keeper:keeper@localhost:5432/keeper
#   PII_FILTER_PRESIDIO_ENABLED=true
#   PII_FILTER_LANGUAGES=hr,en

# ---------------------------------------------------------------------------
# Task 11 — vault encryption-at-rest (Option E: encrypted value + blind index)
# ---------------------------------------------------------------------------
# The blind index (lookup_hash) is ALWAYS computed when the vault runs, so the
# blind-index key is required whenever vault_enabled=true — even with
# encryption disabled. `vault_encryption_enabled` only controls whether
# `original_value` is stored as ciphertext (true) or plaintext (false).
#
# DEV ONLY: the base64 keys below are random throwaway 32-byte keys for local
# Postgres. NEVER use these in any deployed environment — production loads keys
# from Google Secret Manager via PII_FILTER_VAULT_KMS_BACKEND=gcp_kms.
#
# Generate your own 32-byte base64 key with:
#   python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"

#   PII_FILTER_VAULT_ENCRYPTION_ENABLED=true
#   PII_FILTER_VAULT_ENCRYPTION_STRICT=false
#   PII_FILTER_VAULT_KMS_BACKEND=local
#   PII_FILTER_VAULT_ENCRYPTION_KEY=7JHzKQrF6BdDlbi4BtcWyRKpD67L9JSSKAqF73ZZubk=
#   PII_FILTER_VAULT_BLIND_INDEX_KEY=+1Co1EORSwnXqV9mYq6WnCNiHP5GorZdxcQGWC1cfL0=
#   PII_FILTER_VAULT_ENCRYPTION_KEY_ID=1

# gcp_kms backend (production — keys live in Secret Manager, not in env):
#   PII_FILTER_VAULT_KMS_BACKEND=gcp_kms
#   PII_FILTER_VAULT_GCP_ENC_SECRET=projects/<proj>/secrets/<name>/versions/latest
#   PII_FILTER_VAULT_GCP_BLIND_SECRET=projects/<proj>/secrets/<name>/versions/latest
