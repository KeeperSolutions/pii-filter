# Copy to docker/.env (gitignored) before starting the stack:
#
#   cp docker/.env.example docker/.env
#
# and replace the placeholders with freshly generated keys:
#
#   python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
#
# Compose auto-loads docker/.env because the compose file lives in this
# directory. Missing values fail the stack at startup with a named error
# rather than booting into a half-configured vault.

# ---- Vault keys -------------------------------------------------------------
# REQUIRED whenever the vault runs, even with encryption off: lookup_hash is
# NOT NULL and part of the primary key (spec D1), so _build_vault_crypto fails
# closed without it.
#
# Keep this STABLE for the life of a vault volume. The blind index is a keyed
# HMAC, so changing the key orphans every row already written — existing
# placeholders stop resolving and outlet silently stops restoring originals.
PII_FILTER_VAULT_BLIND_INDEX_KEY=<base64-encoded-32-byte-key>

# ---- Optional: encryption at rest -------------------------------------------
# OFF by default in this repo (the deployment copy defaults it ON). Set all
# three to exercise the ENC1 envelope path. The encryption key MUST differ from
# the blind-index key above — on_startup rejects a reused key.
# PII_FILTER_VAULT_ENCRYPTION_ENABLED=true
# PII_FILTER_VAULT_ENCRYPTION_KEY=<base64-encoded-32-byte-key-DIFFERENT-from-above>
# PII_FILTER_VAULT_ENCRYPTION_STRICT=true

# ---- Optional: LLM backend --------------------------------------------------
# OpenWebUI needs a real model connection for chat. Add one in the UI, or set
# these and uncomment the matching lines in docker-compose.yaml.
# OPENAI_API_KEY=sk-...
